# ============================================================
# Módulo "Leads Meta" — variables de entorno
# Copiá lo que falte a tu .env / .env.local
# ============================================================

# --- Google Sheets (Fase 1) ---
# JSON COMPLETO de la key del service account (una sola línea o multilínea).
# Compartí cada hoja (Lector) con el client_email de este service account.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"leads-reader@tu-proyecto.iam.gserviceaccount.com","token_uri":"https://oauth2.googleapis.com/token"}'

# --- Cron de ingesta ---
# Secreto para GET /api/leads/sync (header x-cron-secret).
# Si no está, cae a AUTOMATION_CRON_SECRET (el que ya usa el cron de automations).
LEADS_CRON_SECRET=cambiame-por-un-secreto-largo

# --- Meta Conversions API (CAPI) ---
# Token de la Conversions API. NUNCA se guarda en la base.
# El dataset_id, la etapa disparadora y el evento van en la tabla lead_capi_config.
META_CAPI_ACCESS_TOKEN=
